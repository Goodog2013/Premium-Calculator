{
  "name": "greatcalc",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:web",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "build:desktop": "npm run tauri:build",
    "releases:collect": "node scripts/collect-releases.mjs",
    "releases:clean": "node scripts/clean-releases.mjs",
    "build:all": "npm run releases:clean && npm run build:web && npm run build:desktop && npm run releases:collect",
    "build:web:release": "npm run releases:clean && npm run build:web && npm run releases:collect",
    "build:web": "node scripts/clean-web-dist.mjs && tsc -b && vite build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "mathjs": "^15.2.0",
    "nerdamer": "^1.1.13",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.4.27",
    "balanced-match": "^4.0.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.9",
    "tailwindcss": "^3.4.13",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.4"
  }
}
